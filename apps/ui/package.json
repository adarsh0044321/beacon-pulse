{
  "name": "lanshare-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:host": "tsc && vite build --mode host --outDir dist-host",
    "build:player": "tsc && vite build --mode player --outDir dist-player",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:host": "tauri build -c src-tauri/tauri.host.conf.json",
    "tauri:build:player": "tauri build -c src-tauri/tauri.player.conf.json"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "lucide-react": "^0.378.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
